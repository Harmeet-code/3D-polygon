{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "model": "opencode/qwen3.6-plus",
  "small_model": "opencode/minimax-m2.5",
  "compaction": {
    "auto": true,
    "tail_turns": 15
  },
  "tool_output": {
    "max_lines": 400,
    "max_bytes": 8192
  },
  "formatter": false,
  "lsp": false,
  "plugin": [
    "opencode-scheduler",
    "opencode-conductor-plugin",
    "opencode-firecrawl",
    // "@daytona/opencode",
    "@zenobius/opencode-skillful"
  ],
  "skills": {
    "paths": [".opencode/skills", ".opencode/skill"]
  },
  "command": {
    "check": {
      "description": "Run full project check (lint + format + typecheck)",
      "template": "Run `bun check` and report any errors. Fix lint/format issues if found, then re-run until clean."
    },
    "typecheck": {
      "description": "Run TypeScript type checking",
      "template": "Run `bun typecheck` and report any type errors. Explain the issue and suggest fixes."
    },
    "dev": {
      "description": "Start the dev server",
      "template": "Start the dev server with `bun run dev` on port 3000. Confirm it's running and accessible."
    },
    "add-floor": {
      "description": "Add a new floor to the 3D viewer",
      "template": "Help me add a new floor. I need to: 1) Add the floor name to src/data/floors.json, 2) Create the JSON data file in src/data/json/, 3) Add the floor plan image in src/data/floor plan/, 4) Verify the floor loads correctly. Walk me through each step."
    },
    "calibrate": {
      "description": "Debug and calibrate booth coordinates",
      "template": "Help debug coordinate calibration issues. Check the coordinate pipeline: Fabric JSON → fabricToPixel() → pxToWorld() → 3D World. Review localStorage key `sems_demo_cal_v2` and calibration slider values."
    }
  },
  "agent": {
    "conductor": {
      "model": "opencode/qwen3.6-plus"
    },
    "threejs-expert": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "frontend-ui": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "permission": {
    "read": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "edit": {
      "src/**": "allow",
      ".opencode/**": "allow",
      "opencode.jsonc": "allow",
      "AGENTS.md": "allow",
      "*": "ask"
    },
    "bash": {
      "bun run *": "allow",
      "bun typecheck": "allow",
      "bun lint": "allow",
      "bun format": "allow",
      "bun check": "allow",
      "bun install": "allow",
      "git *": "ask",
      "*": "ask"
    }
  }
}
